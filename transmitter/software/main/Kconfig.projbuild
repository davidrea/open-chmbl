menu "Transmitter configuration"

    config CHMBL_CLI
        bool "Enable developer CLI (console shell)"
        default y
        help
            Build the developer command-line shell (design element DE-00). It
            runs over the console transport selected per target in
            sdkconfig.defaults.<target> (USB Serial/JTAG on the ESP32-C3, UART
            on the classic ESP32).

            Disable for production builds; the shell is then absent from the
            image.

    config CHMBL_STATE_GPIO
        int "Stand-in state-indicator GPIO number"
        range 0 33
        default 8 if IDF_TARGET_ESP32C3
        default 2 if IDF_TARGET_ESP32
        default 2
        help
            GPIO number (IOxx) lit by the `state` console command whenever the
            stand-in braking output state is DECEL or BRAKE, until the real CAN
            decode / state machine / ESP-NOW TX land.

            Defaults to the onboard LED of each target's reference dev board:
            GPIO8 on the ESP32-C3-DevKitM/C, GPIO2 on the classic ESP32-DevKitC.
            (On the classic ESP32 avoid GPIO6-11 — they are wired to the SPI
            flash.) Set this to match the board you are bringing up.

    config CHMBL_CAN_TX_GPIO
        int "TWAI (CAN) TX GPIO number"
        range 0 33
        default 4 if IDF_TARGET_ESP32C3
        default 21
        help
            GPIO wired to the CAN transceiver's TXD (SN65HVD230 D pin). The
            controller runs in listen-only mode and never drives the bus
            dominant, but the TWAI peripheral still requires a TX pin.

    config CHMBL_CAN_RX_GPIO
        int "TWAI (CAN) RX GPIO number"
        range 0 39
        default 5 if IDF_TARGET_ESP32C3
        default 22
        help
            GPIO wired to the CAN transceiver's RXD (SN65HVD230 R pin).

    config CHMBL_NET_CHANNEL
        int "ESP-NOW Wi-Fi channel"
        range 1 13
        default 6
        help
            Fixed 2.4 GHz channel used for ESP-NOW. Must match the
            brake_light's CHMBL_NET_CHANNEL — there's no channel-agreement
            handshake yet (see docs/design/de-01-espnow-link.md open items).

    config CHMBL_NET_RATE_HZ
        int "Default heartbeat rate (Hz)"
        range 1 50
        default 20
        help
            Default ESP-NOW heartbeat rate at boot; override at runtime with
            the `net rate <hz>` console command (TX-CLI-5).

    config CHMBL_PAIR_TIMEOUT_S
        int "Pairing window (seconds)"
        range 3 60
        default 15
        help
            How long `pair start` broadcasts/listens for a peer before
            giving up.

endmenu
