# Default sdkconfig values applied on a fresh build (committed; the generated
# `sdkconfig` is not). Override per-board with `idf.py menuconfig`.
#
# Target-specific values live in sibling sdkconfig.defaults.<target> files that
# IDF applies automatically on top of this one for the selected target:
#   - sdkconfig.defaults.esp32c3   product target — USB Serial/JTAG console
#   - sdkconfig.defaults.esp32     interim dev hardware — UART console
# Pick the target with `idf.py set-target esp32c3` / `esp32` (or the CI matrix).

# Smaller, quieter default log level for shipping firmware.
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
