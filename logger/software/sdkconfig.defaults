# Default sdkconfig values applied on a fresh build (committed; the generated
# `sdkconfig` is not). Override per-board with `idf.py menuconfig`.
#
# Target is the ESP32 on the ESP-WROVER-KIT v4.1. Select it at build time with
# `idf.py set-target esp32` (or the `target` input of the CI action).

# --- PSRAM (the WROVER module carries 4 MB of it; frees internal RAM for the
#     LVGL draw buffers and the CAN write buffering) ---
CONFIG_SPIRAM=y

# --- FAT filesystem: allow long filenames so the microSD's existing files list
#     cleanly even though our own logs are short 8.3 names (N.trc) ---
CONFIG_FATFS_LFN_STACK=y

# --- Smaller, quieter default log level for shipping firmware ---
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
