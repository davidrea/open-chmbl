# Default sdkconfig values applied on a fresh build (committed; the generated
# `sdkconfig` is not). Override per-board with `idf.py menuconfig`.
#
# Target is the ESP32-S3-WROOM-1-N8 on the custom logger board (see
# ../hardware/). Select it at build time with `idf.py set-target esp32s3`
# (or the `target` input of the CI action).
#
# No PSRAM: the -N8 module has none (8 MB flash, no PSRAM), so CONFIG_SPIRAM is
# left off. The internal SRAM is sized for the CAN frame queue / write buffering
# without it; the retired ESP-WROVER-KIT (which did carry 4 MB PSRAM) is gone.

# --- FAT filesystem: allow long filenames so the microSD's existing files list
#     cleanly even though our own logs are short 8.3 names (N.trc) ---
CONFIG_FATFS_LFN_STACK=y

# --- Smaller, quieter default log level for shipping firmware ---
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
